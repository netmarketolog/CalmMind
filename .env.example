# Публичный URL сайта (metadata, sitemap, canonical). На Render: https://your-service.onrender.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Режим основного CTA: waitlist | stripe
NEXT_PUBLIC_CHECKOUT_MODE=waitlist

# Ссылка на лист ожидания (Tally, Google Forms и т.д.) — при waitlist
NEXT_PUBLIC_WAITLIST_URL=

# Stripe (когда подключите оплату)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
